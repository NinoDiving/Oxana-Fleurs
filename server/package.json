{
  "name": "@js-monorepo/server",
  "scripts": {
    "check-types": "tsc --noEmit",
    "dev": "tsx watch --clear-screen=false ./src/main",
    "db:migrate": "tsx ./bin/migrate",
    "db:seed": "ts-node ./bin/seed",
    "build": "tsx ./bin/migrate && tsc ./src/main --outDir ../dist --esModuleInterop",
    "start": "node ../dist/src/main",
    "test": "jest --verbose"
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^6.10.0",
    "stripe": "^17.6.0",
    "vite": "^5.4.18"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^3.12.10",
    "typescript": "^5.6.2"
  }
}
